{
  "name": "dico",
  "displayName": "DICO",
  "description": "Fiches lexicographiques (DICO)",
  "version": "1.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.78.0"
  },
  "categories": ["Programming Languages"],
  "icon": "media/dico.png",
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "dico",
        "aliases": ["Dico", "dico"],
        "extensions": [".dico"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dico",
        "scopeName": "text.dico",
        "path": "./syntaxes/dico.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "dico.compileCurrentFile",
        "title": "DICO: Compile Current File"
      },
      {
        "command": "dico.validateWorkspace",
        "title": "DICO: Validate Workspace"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dico",
          "title": "DICO",
          "icon": "media/dico.svg"
        }
      ]
    },
    "views": {
      "dico": [
        {
          "id": "dico.inspector",
          "name": "Entry Inspector",
          "icon": "media/dico.svg"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p ."
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.78.0",
    "typescript": "^5.4.5"
  }
}
